---
import BaseLayout from './BaseLayout.astro';
const { title, description, module: mod, backHref } = Astro.props;
const hasToc = Astro.slots.has('toc');
---
<BaseLayout title={title} description={description}>

  <!-- HEADER -->
  <header class="header">
    <a href="/" class="header-logo-block">
      <div class="header-logo">Aktu<br/>Notes</div>
      <div class="header-logo-sub">PAI · AAMAI · 2026</div>
    </a>
    <button class="mob-menu-btn" id="mob-menu-btn" aria-label="Menu">☰</button>
    <div class="header-search-block">
      <span class="header-search-icon">⌕</span>
      <input class="header-search" id="site-search" type="text" placeholder="Cari topik, rumus, soal ujian…" autocomplete="off" />
      <div class="search-results" id="search-results" hidden></div>
    </div>
    <div class="header-badge-block">
      <div class="header-badge-text">Aktuaria<br/>Indonesia</div>
    </div>
  </header>

  <!-- BODY -->
  <div class={`body-wrap${hasToc ? '' : ' body-no-toc'}`}>

    <!-- Left sidebar -->
    <aside class="sidebar-left">
      <div class="nav-section-header">▸ PAI Exams</div>

      <details class="nav-group" open={mod === 'CF1' ? true : undefined}>
        <summary class={`nav-group-title${mod === 'CF1' ? ' active' : ''}`}>CF1 — Mat. Keuangan</summary>
        <a href="/CF1"          class="nav-sub-item">Materi & Topik</a>
        <a href="/CF1#past-exams"  class="nav-sub-item">Past Exams</a>
        <a href="/CF1#solutions"   class="nav-sub-item">Solutions</a>
      </details>

      <details class="nav-group" open={mod === 'CF2' ? true : undefined}>
        <summary class={`nav-group-title${mod === 'CF2' ? ' active' : ''}`}>CF2 — Probabilitas</summary>
        <a href="/CF2"          class="nav-sub-item">Materi & Topik</a>
        <a href="/CF2#past-exams"  class="nav-sub-item">Past Exams</a>
        <a href="/CF2#solutions"   class="nav-sub-item">Solutions</a>
      </details>

      <a href="/CF3"  class={`nav-item ${mod === 'CF3'  ? 'active' : ''}`}>CF3 — Ekonomi</a>
      <a href="/CF4"  class={`nav-item ${mod === 'CF4'  ? 'active' : ''}`}>CF4 — Akuntansi</a>
      <a href="/TA1"  class={`nav-item ${mod === 'TA1'  ? 'active' : ''}`}>TA1 — Statistika</a>
      <a href="/TA2"  class={`nav-item ${mod === 'TA2'  ? 'active' : ''}`}>TA2 — Teori Risiko</a>
      <a href="/TA3"  class={`nav-item ${mod === 'TA3'  ? 'active' : ''}`}>TA3 — Mat. Aktuaria</a>
      <a href="/BA4G" class={`nav-item ${mod === 'BA4G' ? 'active' : ''}`}>BA4G — Asuransi Umum</a>

      <div class="nav-section-header">▸ AAMAI</div>
      <details class="nav-group" open={mod === 'AAMAI101' ? true : undefined}>
        <summary class={`nav-group-title${mod === 'AAMAI101' ? ' active' : ''}`}>AAMAI 101</summary>
        <a href="/AAMAI101" class="nav-sub-item">Materi & Topik</a>
      </details>

      <div class="nav-section-header">▸ Resources</div>
      <a href="/formula-sheet" class="nav-item">Formula Sheet CF1</a>
      <a href="/study-log"     class="nav-item">Study Log</a>
    </aside>

    <!-- Main content -->
    <main class="content">
      {backHref && (
        <a href={backHref} class="back-link">← Kembali</a>
      )}
      <slot />
    </main>

    <!-- Right TOC -->
    <aside class="sidebar-right">
      <slot name="toc" />
    </aside>

  </div>

  <!-- Mobile nav overlay -->
  <div class="mob-nav-overlay" id="mob-nav-overlay">
    <nav class="mob-nav-panel" id="mob-nav-panel">
      <button class="mob-nav-close" id="mob-nav-close">✕ &nbsp;Tutup</button>
      <div class="nav-section-header">▸ PAI Exams</div>
      <a href="/CF1"    class="nav-item">CF1 — Mat. Keuangan</a>
      <a href="/CF2"    class="nav-item">CF2 — Probabilitas</a>
      <a href="/CF3"    class="nav-item">CF3 — Ekonomi</a>
      <a href="/CF4"    class="nav-item">CF4 — Akuntansi</a>
      <a href="/TA1"    class="nav-item">TA1 — Statistika</a>
      <a href="/TA2"    class="nav-item">TA2 — Teori Risiko</a>
      <a href="/TA3"    class="nav-item">TA3 — Mat. Aktuaria</a>
      <a href="/BA4G"   class="nav-item">BA4G — Asuransi Umum</a>
      <div class="nav-section-header">▸ AAMAI</div>
      <a href="/AAMAI101" class="nav-item">AAMAI 101</a>
      <div class="nav-section-header">▸ Resources</div>
      <a href="/formula-sheet" class="nav-item">Formula Sheet CF1</a>
    </nav>
  </div>

</BaseLayout>

<style is:global>
  .header {
    position: sticky; top: 0; z-index: 100;
    display: grid;
    grid-template-columns: 210px 1fr 175px;
    align-items: stretch;
    border-bottom: 4px solid var(--ink);
    background: var(--cream);
  }
  .header-logo-block {
    background: var(--pink);
    padding: 0.75rem 1.2rem;
    border-right: 3px solid var(--ink);
    display: flex; flex-direction: column; justify-content: center;
    text-decoration: none;
  }
  .header-logo {
    font-family: var(--ss4);
    font-size: 1.55rem; font-weight: 700;
    color: var(--ink); line-height: 1; letter-spacing: -0.03em;
  }
  .header-logo-sub {
    font-family: var(--mono);
    font-size: 0.55rem; color: rgba(14,10,4,0.55);
    letter-spacing: 0.1em; text-transform: uppercase; margin-top: 0.2rem;
  }
  .header-search-block {
    display: flex; align-items: center;
    padding: 0 1.5rem; gap: 0.8rem;
    border-right: 3px solid var(--ink);
  }
  .header-search-icon { color: var(--ink3); font-size: 0.85rem; }
  .header-search {
    width: 100%; background: none; border: none; outline: none;
    font-family: var(--ss4); font-size: 0.92rem; color: var(--ink);
    border-bottom: 2px solid transparent; padding: 0.2rem 0;
    transition: border-color 0.15s;
  }
  .header-search:focus { border-bottom-color: var(--pink); }
  .header-search::placeholder { color: var(--ink4); font-style: italic; }
  .header-badge-block {
    background: var(--yellow); padding: 0.7rem 1.2rem;
    display: flex; flex-direction: column;
    justify-content: center; align-items: center; width: 175px;
  }
  .header-badge-text {
    font-family: var(--mono); font-size: 0.6rem; color: var(--ink);
    letter-spacing: 0.1em; text-transform: uppercase;
    text-align: center; line-height: 1.6; font-weight: 600;
  }

  /* ── Search results dropdown ── */
  .header-search-block { position: relative; }
  .search-results {
    position: absolute; top: calc(100% + 4px); left: 0; right: 0;
    background: var(--cream); border: 2px solid var(--ink);
    box-shadow: 4px 4px 0 rgba(14,10,4,0.15);
    z-index: 200; max-height: 320px; overflow-y: auto;
  }
  .search-result-item {
    display: block; padding: 0.5rem 0.9rem;
    font-family: var(--mono); font-size: 0.65rem; color: var(--ink2);
    text-decoration: none; border-bottom: 1px solid var(--border2);
    transition: background 0.1s;
  }
  .search-result-item:last-child { border-bottom: none; }
  .search-result-item:hover, .search-result-item.focused {
    background: var(--yellow); color: var(--ink);
  }
  .search-result-item .sr-code {
    color: var(--pink); font-weight: 600; margin-right: 0.4rem;
  }
  .search-result-empty {
    padding: 0.6rem 0.9rem;
    font-family: var(--mono); font-size: 0.62rem;
    color: var(--ink4); font-style: italic;
  }

  .body-wrap {
    display: grid;
    grid-template-columns: 210px 1fr 175px;
    min-height: calc(100vh - 68px);
    position: relative; z-index: 1;
  }

  /* ── Sidebar left ── */
  .sidebar-left {
    border-right: 3px solid var(--ink);
    background: var(--cream);
    display: flex; flex-direction: column;
    overflow-y: auto;
  }
  .nav-section-header {
    background: var(--ink); color: var(--yellow);
    font-family: var(--mono); font-size: 0.55rem;
    letter-spacing: 0.16em; text-transform: uppercase;
    padding: 0.42rem 0.9rem;
  }
  .nav-item {
    font-family: var(--mono); font-size: 0.65rem; color: var(--ink2);
    padding: 0.42rem 0.9rem;
    border-bottom: 1px solid var(--border2);
    cursor: pointer; display: flex;
    align-items: center; justify-content: space-between;
    transition: all 0.1s; text-decoration: none; gap: 0.5rem;
  }
  .nav-item:hover { background: var(--yellow); color: var(--ink); }
  .nav-item.active {
    background: var(--pink); color: #fff;
    border-left: 4px solid var(--ink); font-weight: 500;
  }

  /* ── Nav groups (collapsible) ── */
  .nav-group { border-bottom: 1px solid var(--border2); }
  .nav-group-title {
    font-family: var(--mono); font-size: 0.65rem; color: var(--ink2);
    padding: 0.42rem 0.9rem;
    cursor: pointer; list-style: none;
    display: flex; align-items: center; justify-content: space-between;
    user-select: none; transition: all 0.1s;
  }
  .nav-group-title::-webkit-details-marker { display: none; }
  .nav-group-title::after {
    content: '›'; font-size: 0.95rem; font-weight: 300;
    opacity: 0.4; transition: transform 0.15s; flex-shrink: 0;
  }
  .nav-group[open] > .nav-group-title::after { transform: rotate(90deg); }
  .nav-group-title:hover { background: var(--yellow); color: var(--ink); }
  .nav-group-title.active {
    background: var(--pink); color: #fff;
    border-left: 4px solid var(--ink); font-weight: 500;
  }
  .nav-group-title.active::after { opacity: 0.6; }
  .nav-sub-item {
    font-family: var(--mono); font-size: 0.6rem; color: var(--ink3);
    padding: 0.3rem 0.9rem 0.3rem 1.6rem;
    display: block; text-decoration: none;
    border-bottom: 1px solid var(--border2);
    transition: all 0.1s;
  }
  .nav-sub-item:last-child { border-bottom: none; }
  .nav-sub-item::before { content: '↳ '; opacity: 0.5; }
  .nav-sub-item:hover { background: var(--cream2); color: var(--pink); padding-left: 1.9rem; }

  /* ── Main content ── */
  .content {
    padding: 2.5rem 3rem 4rem;
    overflow-y: auto;
  }
  .back-link {
    display: inline-flex; align-items: center; gap: 0.3rem;
    font-family: var(--mono); font-size: 0.62rem;
    color: var(--ink4); text-decoration: none;
    letter-spacing: 0.06em; margin-bottom: 1.2rem;
    padding: 0.2rem 0.5rem 0.2rem 0;
    border-bottom: 1px solid transparent;
    transition: color 0.12s, border-color 0.12s;
  }
  .back-link:hover { color: var(--pink); border-bottom-color: var(--pink); }

  /* ── Sidebar right ── */
  .sidebar-right {
    border-left: 3px solid var(--ink);
    background: var(--cream2);
  }
  /* TOC content is sticky within the sidebar column */
  .toc-wrap {
    position: sticky;
    top: 68px;
    max-height: calc(100vh - 68px);
    overflow-y: auto;
    padding: 1.5rem 1rem;
  }

  /* ── No-TOC: hide right sidebar, content fills full column ── */
  .body-wrap.body-no-toc {
    grid-template-columns: 210px 1fr;
  }
  .body-wrap.body-no-toc .sidebar-right { display: none; }
  .body-wrap.body-no-toc .content { max-width: none; }

  /* ── Hamburger button (mobile only) ── */
  .mob-menu-btn {
    display: none;
    background: var(--ink); color: var(--yellow);
    border: none; padding: 0 1rem;
    font-size: 1.1rem; cursor: pointer;
    font-family: var(--mono);
    border-left: 3px solid var(--pink);
  }

  /* ── Mobile nav overlay ── */
  .mob-nav-overlay {
    display: none;
    position: fixed; inset: 0; background: rgba(14,10,4,0.5);
    z-index: 150; backdrop-filter: blur(2px);
  }
  .mob-nav-panel {
    position: absolute; top: 0; left: 0;
    width: 240px; height: 100%;
    background: var(--cream); border-right: 3px solid var(--ink);
    display: flex; flex-direction: column;
    overflow-y: auto;
    transform: translateX(-100%);
    transition: transform 0.22s ease;
  }
  .mob-nav-overlay.open { display: block; }
  .mob-nav-overlay.open .mob-nav-panel { transform: translateX(0); }
  .mob-nav-close {
    font-family: var(--mono); font-size: 0.6rem;
    color: var(--ink4); letter-spacing: 0.1em;
    padding: 0.6rem 0.9rem; cursor: pointer;
    border-bottom: 2px solid var(--ink);
    background: var(--ink); color: var(--yellow);
    text-transform: uppercase; border: none;
    text-align: left;
  }

  /* ── TOC sidebar ── */
  .toc-wrap { font-family: var(--mono); }
  .toc-header {
    font-size: 0.6rem; font-weight: 600;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--ink4); padding: 0.7rem 0 0.5rem;
    border-bottom: 2px solid var(--ink);
    margin-bottom: 0.5rem;
  }
  .toc-group {
    border-bottom: 1px solid var(--border2);
    margin-bottom: 0;
  }
  .toc-group-title {
    font-size: 0.6rem; font-weight: 600;
    color: var(--ink2); letter-spacing: 0.04em;
    padding: 0.4rem 0.3rem;
    cursor: pointer; list-style: none;
    display: flex; justify-content: space-between; align-items: center;
    transition: background 0.1s;
  }
  .toc-group-title::-webkit-details-marker { display: none; }
  .toc-group-title:hover { color: var(--pink); }
  .toc-group-title::after {
    content: '›'; font-size: 0.9rem; font-weight: 300;
    transition: transform 0.15s; opacity: 0.5;
  }
  .toc-group[open] .toc-group-title::after { transform: rotate(90deg); }
  .toc-group-items { padding: 0.1rem 0 0.4rem 0.8rem; }
  .toc-item {
    display: block; font-size: 0.58rem;
    color: var(--ink4); text-decoration: none;
    padding: 0.22rem 0.2rem;
    border-left: 2px solid transparent;
    transition: all 0.1s;
  }
  .toc-item:hover { color: var(--pink); border-left-color: var(--pink); padding-left: 0.5rem; }
  .toc-h2-solo {
    font-size: 0.6rem; font-weight: 600; color: var(--ink2);
    display: block; padding: 0.4rem 0.3rem; text-decoration: none;
    border-bottom: 1px solid var(--border2);
    transition: color 0.1s;
  }
  .toc-h2-solo:hover { color: var(--pink); }

  @media (max-width: 900px) {
    .header { grid-template-columns: auto 1fr auto; }
    .header-badge-block { display: none; }
    .body-wrap { grid-template-columns: 1fr; }
    .sidebar-left { display: none; }
    .body-wrap.body-no-toc { grid-template-columns: 1fr; }
    .mob-menu-btn { display: flex; align-items: center; }
    .sidebar-right {
      border-left: none; border-top: 3px solid var(--ink);
      background: var(--cream2); padding: 1rem 1.2rem;
      max-height: 280px;
    }
    .content { padding: 1.5rem 1.2rem 3rem; max-width: 100%; }
  }

  @media (max-width: 600px) {
    .header { grid-template-columns: auto 1fr auto; }
    .header-search-block { padding: 0 0.8rem; }
    .header-search { font-size: 0.82rem; }
    .content { padding: 1.2rem 1rem 3rem; }
    .sidebar-right { display: none; }
  }

  /* ══════════════════════════════════
     OBSIDIAN CALLOUTS
  ══════════════════════════════════ */
  details.callout {
    border: 2px solid;
    margin: 1rem 0;
    overflow: hidden;
  }

  .callout-title {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 0.9rem;
    font-family: var(--mono);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }
  .callout-title::-webkit-details-marker { display: none; }

  .callout-icon { flex-shrink: 0; }
  .callout-label { flex: 1; }
  .callout-fold {
    font-size: 1rem; font-weight: 300;
    transition: transform 0.2s;
    display: inline-block;
  }
  details.callout[open] .callout-fold { transform: rotate(90deg); }

  .callout-body {
    padding: 0.75rem 1rem;
    border-top: 1px solid rgba(0,0,0,0.08);
  }
  .callout-body > *:last-child { margin-bottom: 0; }

  /* Nested callouts */
  .callout-body details.callout { margin: 0.6rem 0; }

  /* ── Callout type colors ── */

  /* note / info */
  .callout-note, .callout-info, .callout-todo {
    border-color: #3b82f6;
  }
  .callout-note .callout-title,
  .callout-info .callout-title,
  .callout-todo .callout-title {
    background: #dbeafe; color: #1d4ed8;
  }

  /* tip / hint / important */
  .callout-tip, .callout-hint, .callout-important {
    border-color: #059669;
  }
  .callout-tip .callout-title,
  .callout-hint .callout-title,
  .callout-important .callout-title {
    background: #d1fae5; color: #065f46;
  }

  /* abstract / summary / tldr */
  .callout-abstract, .callout-summary, .callout-tldr {
    border-color: #6366f1;
  }
  .callout-abstract .callout-title,
  .callout-summary .callout-title,
  .callout-tldr .callout-title {
    background: #e0e7ff; color: #4338ca;
  }

  /* success / check / done */
  .callout-success, .callout-check, .callout-done {
    border-color: #22c55e;
  }
  .callout-success .callout-title,
  .callout-check .callout-title,
  .callout-done .callout-title {
    background: #dcfce7; color: #15803d;
  }

  /* question / help / faq */
  .callout-question, .callout-help, .callout-faq {
    border-color: #eab308;
  }
  .callout-question .callout-title,
  .callout-help .callout-title,
  .callout-faq .callout-title {
    background: #fefce8; color: #854d0e;
  }

  /* warning / caution / attention */
  .callout-warning, .callout-caution, .callout-attention {
    border-color: #f97316;
  }
  .callout-warning .callout-title,
  .callout-caution .callout-title,
  .callout-attention .callout-title {
    background: #ffedd5; color: #c2410c;
  }

  /* bug */
  .callout-bug {
    border-color: #ef4444;
  }
  .callout-bug .callout-title {
    background: #fee2e2; color: #b91c1c;
  }

  /* failure / fail / missing / danger / error */
  .callout-failure, .callout-fail, .callout-missing,
  .callout-danger, .callout-error {
    border-color: var(--pink);
  }
  .callout-failure .callout-title,
  .callout-fail .callout-title,
  .callout-missing .callout-title,
  .callout-danger .callout-title,
  .callout-error .callout-title {
    background: var(--pink-dim); color: var(--pink);
  }

  /* example */
  .callout-example {
    border-color: #8b5cf6;
  }
  .callout-example .callout-title {
    background: #f5f3ff; color: #6d28d9;
  }

  /* quote / cite */
  .callout-quote, .callout-cite {
    border-color: var(--ink3);
  }
  .callout-quote .callout-title,
  .callout-cite .callout-title {
    background: var(--cream2); color: var(--ink3);
  }

  /* ── Static callouts (non-collapsible) ── */
  .callout-static > .callout-title {
    cursor: default;
    pointer-events: none;
  }
  .callout-static > .callout-title .callout-fold { display: none; }
</style>

<script>
  // ── Instant search ──
  const SEARCH_INDEX = [
    { code: 'CF1', title: 'Matematika Keuangan', url: '/CF1', tags: 'anuitas annuity bunga interest bond obligasi derivatif matematika keuangan' },
    { code: 'CF2', title: 'Probabilitas & Statistika', url: '/CF2', tags: 'probabilitas statistika distribusi variabel acak peluang estimasi hipotesis' },
    { code: 'CF3', title: 'Ekonomi & Pasar Keuangan', url: '/CF3', tags: 'ekonomi makro mikro pasar keuangan' },
    { code: 'CF4', title: 'Akuntansi & Manaj. Keuangan', url: '/CF4', tags: 'akuntansi laporan keuangan manajemen modal rasio' },
    { code: 'TA1', title: 'Metode Statistika', url: '/TA1', tags: 'regresi linear model statistika analisis data' },
    { code: 'TA2', title: 'Teori Risiko', url: '/TA2', tags: 'risiko kredibilitas ruin theory model' },
    { code: 'TA3', title: 'Matematika Aktuaria', url: '/TA3', tags: 'aktuaria asuransi jiwa anuitas hidup mortalitas' },
    { code: 'BA4G', title: 'Asuransi Umum', url: '/BA4G', tags: 'asuransi umum rating klaim reasuransi cadangan' },
    { code: '101', title: 'AAMAI 101 — Prinsip Asuransi', url: '/AAMAI101', tags: 'aamai prinsip asuransi risiko underwriting klaim' },
    { code: 'CF1', title: '1.1 Interest Rates and Discount Rates', url: '/CF1/1-1-interest-rates-and-discount-rates', tags: 'interest discount rate effective nominal' },
    { code: 'CF1', title: '1.2 Effective, Nominal, and Force of Interest', url: '/CF1/1-2-effective-nominal-and-force-of-interest', tags: 'effective nominal force interest' },
    { code: 'CF1', title: '1.3 Cash Flow Equations and Inflation', url: '/CF1/1-3-cash-flow-equations-and-inflation', tags: 'cash flow inflation' },
    { code: 'CF1', title: '1.4 Accumulation and Present Value', url: '/CF1/1-4-accumulation-and-present-value', tags: 'accumulation present value' },
    { code: 'CF1', title: '1.5 NPV, IRR, DWRR, TWRR', url: '/CF1/1-5-npv-irr-dwrr-twrr', tags: 'npv irr dwrr twrr yield' },
    { code: 'CF1', title: '2.1 Annuity-Immediate and Annuity-Due', url: '/CF1/2-1-annuity-immediate-and-annuity-due', tags: 'annuity immediate due anuitas' },
    { code: 'CF1', title: '2.2 Perpetuity', url: '/CF1/2-2-perpetuity', tags: 'perpetuity perpetuitas' },
    { code: 'CF1', title: '2.3 Varying Annuities', url: '/CF1/2-3-varying-annuities', tags: 'varying annuity anuitas berubah' },
    { code: 'CF1', title: '3.3 Duration (Macaulay & Modified)', url: '/CF1/3-3-duration-macaulay-and-modified', tags: 'duration macaulay modified durasi' },
    { code: 'CF1', title: '3.5 Immunization', url: '/CF1/3-5-immunization', tags: 'immunization imunisasi konveksitas' },
    { code: 'CF1', title: '5.1 Bond Pricing', url: '/CF1/5-1-bond-pricing', tags: 'bond obligasi pricing harga' },
    { code: 'CF2', title: '2.5 Distribusi Diskrit Umum', url: '/CF2/2-5-distribusi-diskrit-umum', tags: 'binomial poisson geometric distribusi diskrit' },
    { code: 'CF2', title: '2.6 Distribusi Kontinu Umum', url: '/CF2/2-6-distribusi-kontinu-umum', tags: 'normal exponential gamma distribusi kontinu' },
    { code: 'CF2', title: '4.3 Teorema Limit Pusat (CLT)', url: '/CF2/4-3-teorema-limit-pusat-clt', tags: 'clt central limit theorem' },
    { code: 'CF2', title: '4.8 Uji Hipotesis', url: '/CF2/4-8-uji-hipotesis', tags: 'uji hipotesis hypothesis testing p-value' },
  ];

  const searchInput = document.getElementById('site-search') as HTMLInputElement | null;
  const searchResults = document.getElementById('search-results') as HTMLDivElement | null;
  if (!searchInput || !searchResults) throw new Error();

  let focusedIdx = -1;

  function renderResults(query: string) {
    const q = query.trim().toLowerCase();
    if (!q) { searchResults!.hidden = true; return; }

    const matches = SEARCH_INDEX.filter(item =>
      item.title.toLowerCase().includes(q) ||
      item.code.toLowerCase().includes(q) ||
      item.tags.toLowerCase().includes(q)
    ).slice(0, 8);

    if (matches.length === 0) {
      searchResults!.innerHTML = `<div class="search-result-empty">Tidak ada hasil untuk "<em>${q}</em>"</div>`;
    } else {
      searchResults!.innerHTML = matches.map((item, i) =>
        `<a class="search-result-item" href="${item.url}" data-idx="${i}">
          <span class="sr-code">${item.code}</span>${item.title}
        </a>`
      ).join('');
    }
    searchResults!.hidden = false;
    focusedIdx = -1;
  }

  searchInput.addEventListener('input', () => renderResults(searchInput.value));

  searchInput.addEventListener('keydown', (e) => {
    const items = searchResults!.querySelectorAll<HTMLElement>('.search-result-item');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      focusedIdx = Math.min(focusedIdx + 1, items.length - 1);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      focusedIdx = Math.max(focusedIdx - 1, -1);
    } else if (e.key === 'Enter' && focusedIdx >= 0) {
      e.preventDefault();
      items[focusedIdx]?.click();
    } else if (e.key === 'Escape') {
      searchResults!.hidden = true;
    }
    items.forEach((el, i) => el.classList.toggle('focused', i === focusedIdx));
    if (focusedIdx >= 0) items[focusedIdx]?.scrollIntoView({ block: 'nearest' });
  });

  document.addEventListener('click', (e) => {
    if (!searchInput.contains(e.target as Node) && !searchResults!.contains(e.target as Node)) {
      searchResults!.hidden = true;
    }
  });

  searchInput.addEventListener('focus', () => {
    if (searchInput.value.trim()) renderResults(searchInput.value);
  });

  // ── Mobile nav ──
  const menuBtn = document.getElementById('mob-menu-btn');
  const overlay = document.getElementById('mob-nav-overlay');
  const closeBtn = document.getElementById('mob-nav-close');
  menuBtn?.addEventListener('click', () => overlay?.classList.add('open'));
  closeBtn?.addEventListener('click', () => overlay?.classList.remove('open'));
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) overlay.classList.remove('open');
  });
</script>
