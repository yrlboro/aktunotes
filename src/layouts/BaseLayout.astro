---
import '../styles/global.css';
const { title = 'AktuNotes', description = 'Catatan belajar ujian PAI & AAMAI' } = Astro.props;
---
<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} · AktuNotes</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,500;0,8..60,600;0,8..60,700;1,8..60,300;1,8..60,400;1,8..60,500&family=Geist+Mono:wght@400;500&display=swap" />
</head>
<body>
  <slot />
</body>

<script is:inline>
  // ── Mermaid: render via CDN (avoids Vite bundling issues with mermaid v11) ──
  (async () => {
    const blocks = document.querySelectorAll('pre[data-language="mermaid"] code, pre code.language-mermaid');
    if (!blocks.length) return;

    const { default: mermaid } = await import('https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs');
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'loose',
      theme: 'base',
      themeVariables: {
        primaryColor: '#f7e03c',
        primaryTextColor: '#0e0a04',
        primaryBorderColor: '#0e0a04',
        lineColor: '#2a1e10',
        secondaryColor: '#faf5e4',
        tertiaryColor: '#f3ecda',
        background: '#faf5e4',
        mainBkg: '#faf5e4',
        nodeBorder: '#0e0a04',
        clusterBkg: '#f3ecda',
        titleColor: '#0e0a04',
        edgeLabelBackground: '#faf5e4',
        fontFamily: "'Geist Mono', monospace",
        fontSize: '13px',
      },
    });

    let idx = 0;
    for (const el of blocks) {
      const pre = el.parentElement;
      const code = (el.textContent || '').trim();
      const id = 'mermaid-' + idx++;
      try {
        const { svg } = await mermaid.render(id, code);
        const div = document.createElement('div');
        div.className = 'mermaid';
        div.innerHTML = svg;
        pre.replaceWith(div);
      } catch (err) {
        console.warn('Mermaid render failed for block:', id, err);
      }
    }
  })();
</script>
</html>