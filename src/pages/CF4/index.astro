---
import { getCollection } from 'astro:content';
import NoteLayout from '../../layouts/NoteLayout.astro';

const allEntries = await getCollection('cf4');
const notes = allEntries.sort((a, b) => a.id.localeCompare(b.id));

function formatTitle(id: string): string {
  return id.split('/').pop()!
    .replace(/-/g, ' ')
    .replace(/\b\w/g, c => c.toUpperCase());
}
---

<NoteLayout title="CF4 — Akuntansi dan Keuangan Korporasi" description="Pelaporan keuangan, perpajakan, sekuritas, pembiayaan korporasi, pasar keuangan." module="CF4">

  <div class="page-eyebrow">CF4 · Akuntansi dan Keuangan Korporasi</div>
  <h1>Akuntansi &<br/><em>Keuangan Korporasi</em></h1>

  <div class="h1-rule">
    <div class="h1-rule-line"></div>
    <div class="h1-rule-dot"></div>
    <div class="h1-rule-dot" style="background:var(--yellow)"></div>
    <div class="h1-rule-dot" style="background:var(--ink)"></div>
  </div>

  <p>
    Modul CF4 mencakup <strong>pelaporan keuangan dan perpajakan</strong>, sekuritas dan bentuk
    keuangan korporasi, pembiayaan korporasi, serta struktur pasar keuangan.
    Ujian 3 jam · 40 soal pilihan ganda.
  </p>

  <h2 id="topik">▸ Materi & Silabus</h2>

  <div class="topic-list">
    {notes.map(entry => (
      <a href={`/CF4/${entry.id}`} class="topic-item">
        <span class="topic-num">{entry.data.topic_id || '—'}</span>
        <span class="topic-name">{entry.data.topic || entry.data.title || formatTitle(entry.id)}</span>
        {entry.data.difficulty && <span class="topic-diff">{entry.data.difficulty}</span>}
        <span class="topic-arrow">→</span>
      </a>
    ))}
  </div>

</NoteLayout>

<style>
  .page-eyebrow {
    font-family: var(--mono);
    font-size: 0.62rem; color: var(--pink);
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 0.5rem;
    display: flex; align-items: center; gap: 0.4rem;
  }
  .page-eyebrow::before { content: '◆'; font-size: 0.42rem; }
  h1 em { font-style: italic; font-weight: 300; color: var(--pink); }
  .h1-rule {
    display: flex; align-items: center; gap: 0.7rem;
    margin: 0.6rem 0 1.2rem;
  }
  .h1-rule-line { flex: 1; height: 3px; background: var(--ink); }
  .h1-rule-dot { width: 8px; height: 8px; background: var(--pink); flex-shrink: 0; }
  .topic-list {
    display: flex; flex-direction: column;
    border: 2px solid var(--ink);
    margin-bottom: 2rem;
  }
  .topic-item {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none; color: inherit;
    transition: background 0.1s;
  }
  .topic-item:last-child { border-bottom: none; }
  .topic-item:hover { background: var(--yellow); }
  .topic-num {
    font-family: var(--mono); font-size: 0.6rem;
    color: var(--ink4); letter-spacing: 0.08em; min-width: 1.8rem;
  }
  .topic-name {
    font-family: var(--ss4); font-size: 0.95rem; font-weight: 500;
    color: var(--ink); flex: 1;
  }
  .topic-arrow { font-family: var(--mono); font-size: 0.8rem; color: var(--pink); }
  .topic-diff { font-family: var(--mono); font-size: 0.54rem; color: var(--ink4); background: var(--cream3); padding: 0.08rem 0.4rem; flex-shrink: 0; }
  @media (max-width: 600px) {
    .topic-item { gap: 0.6rem; padding: 0.7rem 0.8rem; }
    .topic-num { min-width: 1.5rem; font-size: 0.55rem; }
    .topic-name { font-size: 0.88rem; }
    .topic-diff { display: none; }
    .topic-arrow { font-size: 0.7rem; }
  }
</style>
