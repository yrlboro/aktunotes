---
import BaseLayout from '../../../layouts/BaseLayout.astro';

const CF2_PACKAGES = [
  { slug: 'p1', label: 'Paket 1', soal: 35, durasi: '3 jam' },
  { slug: 'p2', label: 'Paket 2', soal: 35, durasi: '3 jam' },
  { slug: 'p3', label: 'Paket 3', soal: 35, durasi: '3 jam' },
  { slug: 'p4', label: 'Paket 4', soal: 35, durasi: '3 jam' },
  { slug: 'p5', label: 'Paket 5', soal: 35, durasi: '3 jam' },
  { slug: 'p6', label: 'Paket 6', soal: 35, durasi: '3 jam' },
  { slug: 'p7', label: 'Paket 7', soal: 35, durasi: '3 jam' },
];
---

<BaseLayout title="Simulasi Ujian CF2" description="Pilih paket soal simulasi ujian CF2">
  <div class="sel-wrap">
    <div class="sel-header">
      <a href="/CF2" class="sel-back">← CF2</a>
      <div class="sel-title-block">
        <div class="sel-eyebrow">Simulasi Ujian</div>
        <h1 class="sel-h1">CF2 — Probabilitas &amp; Statistika</h1>
      </div>
    </div>

    <p class="sel-desc">
      Pilih paket soal di bawah ini untuk memulai simulasi. Setiap paket terdiri dari soal
      pilihan ganda dengan durasi 3 jam, sesuai format ujian PAI sesungguhnya.
    </p>

    <div class="pkg-grid">
      {CF2_PACKAGES.map(pkg => (
        <a href={`/exam-sim/cf2/${pkg.slug}`} class="pkg-card">
          <div class="pkg-label">{pkg.label}</div>
          <div class="pkg-meta">{pkg.durasi}</div>
          <div class="pkg-arrow">Mulai →</div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style is:global>
  body { background: var(--cream); margin: 0; }
</style>

<style>
  .sel-wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }

  .sel-header {
    display: flex;
    align-items: flex-start;
    gap: 1.2rem;
    margin-bottom: 1.8rem;
  }

  .sel-back {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--ink4);
    text-decoration: none;
    letter-spacing: 0.06em;
    padding-top: 0.5rem;
    flex-shrink: 0;
    transition: color 0.1s;
  }
  .sel-back:hover { color: var(--ink); }

  .sel-eyebrow {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--pink);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    margin-bottom: 0.3rem;
  }

  .sel-h1 {
    font-family: var(--ss4);
    font-size: 2rem;
    font-weight: 700;
    color: var(--ink);
    margin: 0;
    line-height: 1.1;
  }

  .sel-desc {
    font-family: var(--ss4);
    font-size: 0.95rem;
    color: var(--ink3);
    line-height: 1.7;
    margin-bottom: 2.5rem;
    border-left: 3px solid var(--border);
    padding-left: 1rem;
  }

  .pkg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.8rem;
  }

  .pkg-card {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 1.1rem 1.2rem;
    border: 2px solid var(--border);
    background: var(--cream2);
    text-decoration: none;
    transition: all 0.12s;
    cursor: pointer;
  }
  .pkg-card:hover {
    border-color: var(--ink);
    background: var(--cream3);
  }

  .pkg-label {
    font-family: var(--ss4);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: -0.01em;
  }

  .pkg-meta {
    font-family: var(--mono);
    font-size: 0.58rem;
    color: var(--ink4);
    letter-spacing: 0.06em;
  }

  .pkg-arrow {
    font-family: var(--mono);
    font-size: 0.6rem;
    color: var(--pink);
    letter-spacing: 0.04em;
    margin-top: 0.4rem;
  }
</style>
