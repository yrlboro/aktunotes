---
import { getCollection } from 'astro:content';
import NoteLayout from '../../layouts/NoteLayout.astro';

const allEntries = await getCollection('cf2');

// Split into notes and exams
const notes = allEntries
  .filter(e => !e.id.startsWith('exams/') && !e.id.startsWith('soa-sample-questions/'))
  .sort((a, b) => (a.id > b.id ? 1 : -1));

const exams = allEntries
  .filter(e => e.id.startsWith('exams/') && !e.id.includes('solutions/'))
  .sort((a, b) => b.id.localeCompare(a.id));

const solutions = allEntries
  .filter(e => e.id.includes('solutions/'))
  .sort((a, b) => b.id.localeCompare(a.id));

const soaExams = allEntries
  .filter(e => e.id.startsWith('soa-sample-questions/'))
  .sort((a, b) => a.id.localeCompare(b.id));
---

<NoteLayout title="CF2 — Probabilitas & Statistika" module="CF2">

  <div class="page-eyebrow">CF2 · Probabilitas & Statistika</div>
  <h1>Probabilitas<br/><em>& Statistika</em></h1>
  <div class="h1-rule">
    <div class="h1-rule-line"></div>
    <div class="h1-rule-dot"></div>
    <div class="h1-rule-dot" style="background:var(--yellow)"></div>
    <div class="h1-rule-dot" style="background:var(--ink)"></div>
  </div>
  <p>Modul CF2 mencakup <strong>probabilitas</strong>, variabel acak, distribusi peluang, dan <strong>inferensi statistika</strong>.</p>

  <h2 id="topik">▸ Materi</h2>
  <div class="topic-list">
    {notes.map(entry => (
      <a href={`/CF2/${entry.id}`} class="topic-item">
        <span class="topic-num">{entry.data.topic_id || '—'}</span>
        <span class="topic-name">{entry.data.topic || entry.id.split('/').pop()?.replace(/-/g, ' ')}</span>
        {entry.data.difficulty && <span class="topic-diff">{entry.data.difficulty}</span>}
        <span class="topic-arrow">→</span>
      </a>
    ))}
  </div>

  {exams.length > 0 && (
    <>
      <h2 id="past-exams">▸ Past Exams</h2>
      <div class="topic-list">
        {exams.map(entry => (
          <a href={`/CF2/${entry.id}`} class="topic-item topic-exam">
            <span class="topic-num exam-icon">✎</span>
            <span class="topic-name">{entry.id.split('/').pop()?.replace(/-/g, ' ').toUpperCase()}</span>
            <span class="topic-arrow">→</span>
          </a>
        ))}
      </div>
    </>
  )}

  {solutions.length > 0 && (
    <>
      <h2 id="solutions">▸ Past Exam Solutions</h2>
      <div class="topic-list">
        {solutions.map(entry => (
          <a href={`/CF2/${entry.id}`} class="topic-item topic-solution">
            <span class="topic-num solution-icon">✔</span>
            <span class="topic-name">{entry.id.split('/').pop()?.replace(/-/g, ' ').toUpperCase()}</span>
            <span class="topic-arrow">→</span>
          </a>
        ))}
      </div>
    </>
  )}

  {soaExams.length > 0 && (
    <>
      <h2 id="soa-samples">▸ SOA Sample Questions (Exam P)</h2>
      <div class="topic-list">
        {soaExams.map(entry => (
          <a href={`/CF2/${entry.id}`} class="topic-item topic-soa">
            <span class="topic-num soa-icon">◉</span>
            <span class="topic-name">{entry.data.title || entry.id.split('/').pop()?.replace(/-/g, ' ').toUpperCase()}</span>
            <span class="topic-arrow">→</span>
          </a>
        ))}
      </div>
    </>
  )}

</NoteLayout>

<style>
  .page-eyebrow { font-family: var(--mono); font-size: 0.62rem; color: var(--pink); letter-spacing: 0.16em; text-transform: uppercase; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.4rem; }
  .page-eyebrow::before { content: '◆'; font-size: 0.42rem; }
  h1 em { font-style: italic; font-weight: 300; color: var(--pink); }
  .h1-rule { display: flex; align-items: center; gap: 0.7rem; margin: 0.6rem 0 1.2rem; }
  .h1-rule-line { flex: 1; height: 3px; background: var(--ink); }
  .h1-rule-dot { width: 8px; height: 8px; background: var(--pink); flex-shrink: 0; }
  .topic-list { display: flex; flex-direction: column; border: 2px solid var(--ink); margin-bottom: 2rem; }
  .topic-item { display: flex; align-items: center; gap: 1rem; padding: 0.65rem 1rem; border-bottom: 1px solid var(--border); text-decoration: none; color: inherit; transition: background 0.1s; }
  .topic-item:last-child { border-bottom: none; }
  .topic-item:hover { background: var(--yellow); }
  .topic-exam:hover { background: var(--cream3); }
  .topic-num { font-family: var(--mono); font-size: 0.6rem; color: var(--ink4); letter-spacing: 0.08em; min-width: 2.5rem; }
  .exam-icon { color: var(--teal); }
  .topic-solution:hover { background: #d1fae5; }
  .solution-icon { color: #059669; }
  .topic-soa:hover { background: #ede9fe; }
  .soa-icon { color: #7c3aed; }
  .topic-name { font-family: var(--ss4); font-size: 0.95rem; font-weight: 500; color: var(--ink); flex: 1; }
  .topic-diff { font-family: var(--mono); font-size: 0.54rem; color: var(--ink4); background: var(--cream3); padding: 0.08rem 0.4rem; }
  .topic-arrow { font-family: var(--mono); font-size: 0.8rem; color: var(--pink); }
</style>
