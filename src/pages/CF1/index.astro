---
import { getCollection } from 'astro:content';
import NoteLayout from '../../layouts/NoteLayout.astro';

const allEntries = await getCollection('cf1');
const notes = allEntries
  .filter(e => !e.id.startsWith('exams/') && !e.id.startsWith('soa-asm-practice-exams/'))
  .sort((a, b) => a.id.localeCompare(b.id));
const exams = allEntries
  .filter(e => e.id.startsWith('exams/') && !e.id.includes('solutions/'))
  .sort((a, b) => b.id.localeCompare(a.id));
const solutions = allEntries
  .filter(e => e.id.includes('solutions/'))
  .sort((a, b) => {
    const numA = parseInt(a.id.split('/').pop() ?? '0');
    const numB = parseInt(b.id.split('/').pop() ?? '0');
    return numA - numB;
  });
const asmExams = allEntries
  .filter(e => e.id.startsWith('soa-asm-practice-exams/'))
  .sort((a, b) => a.id.localeCompare(b.id));
---

<NoteLayout title="CF1 — Matematika Keuangan" description="Catatan CF1: Nilai waktu uang, anuitas, pinjaman, obligasi, dan derivatif." module="CF1">

  <div class="page-eyebrow">CF1 · Matematika Keuangan</div>
  <h1>Matematika<br/><em>Keuangan</em></h1>

  <div class="h1-rule">
    <div class="h1-rule-line"></div>
    <div class="h1-rule-dot"></div>
    <div class="h1-rule-dot" style="background:var(--yellow)"></div>
    <div class="h1-rule-dot" style="background:var(--ink)"></div>
  </div>

  <p>
    Modul CF1 mencakup konsep dasar <strong>nilai waktu uang</strong>, anuitas, amortisasi pinjaman,
    penilaian obligasi, dan pengantar derivatif keuangan.
    Materi ini menjadi fondasi untuk seluruh ujian aktuaria lanjutan.
  </p>

  <h2 id="topik">▸ Daftar Topik</h2>

  <div class="topic-list">
    {notes.map(entry => (
      <a href={`/CF1/${entry.id}`} class="topic-item">
        <span class="topic-num">{entry.data.topic_id || '—'}</span>
        <span class="topic-name">{entry.data.topic || entry.id.split('/').pop()?.replace(/-/g, ' ')}</span>
        {entry.data.difficulty && <span class="topic-diff">{entry.data.difficulty}</span>}
        <span class="topic-arrow">→</span>
      </a>
    ))}
  </div>

  {exams.length > 0 && (
    <>
      <h2 id="past-exams">▸ Past Exams</h2>
      <div class="topic-list">
        {exams.map(entry => (
          <a href={`/CF1/${entry.id}`} class="topic-item topic-exam">
            <span class="topic-num exam-icon">✎</span>
            <span class="topic-name">{entry.id.split('/').pop()?.toUpperCase()}</span>
            <span class="topic-arrow">→</span>
          </a>
        ))}
      </div>
    </>
  )}

  {solutions.length > 0 && (
    <>
      <h2 id="solutions">▸ Past Exam Solutions</h2>
      <div class="topic-list">
        {solutions.map(entry => (
          <a href={`/CF1/${entry.id}`} class="topic-item topic-solution">
            <span class="topic-num solution-icon">✔</span>
            <span class="topic-name">{entry.id.split('/').pop()?.toUpperCase()}</span>
            <span class="topic-arrow">→</span>
          </a>
        ))}
      </div>
    </>
  )}

  {asmExams.length > 0 && (
    <>
      <h2 id="soa-asm">▸ SOA-ASM Practice Exams</h2>
      <div class="topic-list">
        {asmExams.map(entry => (
          <a href={`/CF1/${entry.id}`} class="topic-item topic-asm">
            <span class="topic-num asm-icon">◉</span>
            <span class="topic-name">{entry.data.title || entry.id.split('/').pop()?.toUpperCase()}</span>
            <span class="topic-arrow">→</span>
          </a>
        ))}
      </div>
    </>
  )}


</NoteLayout>

<style>
  .page-eyebrow {
    font-family: var(--mono);
    font-size: 0.62rem; color: var(--pink);
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 0.5rem;
    display: flex; align-items: center; gap: 0.4rem;
  }
  .page-eyebrow::before { content: '◆'; font-size: 0.42rem; }

  h1 em { font-style: italic; font-weight: 300; color: var(--pink); }

  .h1-rule {
    display: flex; align-items: center; gap: 0.7rem;
    margin: 0.6rem 0 1.2rem;
  }
  .h1-rule-line { flex: 1; height: 3px; background: var(--ink); }
  .h1-rule-dot { width: 8px; height: 8px; background: var(--pink); flex-shrink: 0; }

  .topic-list {
    display: flex; flex-direction: column;
    border: 2px solid var(--ink);
    margin-bottom: 2rem;
  }
  .topic-item {
    display: flex; align-items: center; gap: 1rem;
    padding: 0.65rem 1rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none; color: inherit;
    transition: background 0.1s;
  }
  .topic-item:last-child { border-bottom: none; }
  .topic-item:hover { background: var(--yellow); }
  .topic-num {
    font-family: var(--mono); font-size: 0.6rem;
    color: var(--ink4); letter-spacing: 0.08em; min-width: 1.8rem;
  }
  .topic-name {
    font-family: var(--ss4); font-size: 0.95rem; font-weight: 500;
    color: var(--ink); flex: 1;
  }
  .topic-arrow {
    font-family: var(--mono); font-size: 0.8rem; color: var(--pink);
  }
  .topic-diff { font-family: var(--mono); font-size: 0.54rem; color: var(--ink4); background: var(--cream3); padding: 0.08rem 0.4rem; flex-shrink: 0; }
  .topic-exam:hover { background: var(--cream3); }
  .exam-icon { color: var(--teal); }
  .topic-solution:hover { background: #d1fae5; }
  .solution-icon { color: #059669; }
  .topic-asm:hover { background: #ede9fe; }
  .asm-icon { color: #7c3aed; }

  @media (max-width: 600px) {
    .topic-item { gap: 0.6rem; padding: 0.7rem 0.8rem; }
    .topic-num { min-width: 1.5rem; font-size: 0.55rem; }
    .topic-name { font-size: 0.88rem; }
    .topic-diff { display: none; }
    .topic-arrow { font-size: 0.7rem; }
  }

</style>
